{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"python .agents/hooks/pre_tool_use_policy.py\"",
            "timeout": 30,
            "statusMessage": "Checking harness policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"python .agents/hooks/post_tool_use_review.py\"",
            "timeout": 30,
            "statusMessage": "Reviewing harness risk"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"python .agents/hooks/stop_quality_gate.py\"",
            "timeout": 30,
            "statusMessage": "Running final harness quality gate"
          }
        ]
      }
    ]
  }
}
